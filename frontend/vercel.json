{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "devCommand": "npx vite",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/proxy.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "function": "api/proxy.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
