{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "devCommand": "npx vite",
  "installCommand": "npm install",
  "framework": null,
  "trailingSlash": false,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "dest": "https://web-production-74ed0.up.railway.app/api/:path*"
    },
    {
      "source": "/:path*(.*)",
      "dest": "/index.html"
    }
  ]
}
