{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "devCommand": "npx vite",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/api/:match*",
      "function": "api/chat",
      "force": true
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
