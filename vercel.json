{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "torq-console",
  "buildCommand": "cd frontend && test -f src/components/ui/Badge.tsx && npm install && npx vite build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "installCommand": "echo 'skip root install'",
  "functions": {
    "api/proxy.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/chat/:path*",
      "function": "api/proxy.ts"
    },
    {
      "source": "/api/chat",
      "function": "api/proxy.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "TORQ_CONSOLE_PRODUCTION": "true",
    "TORQ_DISABLE_LOCAL_LLM": "true",
    "TORQ_DISABLE_GPU": "true",
    "PYTHON_VERSION": "3.11"
  }
}
