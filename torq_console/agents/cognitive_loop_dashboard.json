{
  "dashboard": {
    "title": "TORQ Agent Cognitive Loop Observability",
    "tags": ["torq", "agents", "cognitive", "ai"],
    "timezone": "browser",
    "schemaVersion": 36,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Cognitive Loop Latency Distribution",
        "type": "histogram",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "min": 0,
            "max": 10000,
            "decimals": 1
          }
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(torq_cognitive_loop_latency_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(torq_cognitive_loop_latency_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(torq_cognitive_loop_latency_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 2,
        "title": "Cognitive Loops Throughput",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {"mode": "palette-classic"}
          }
        },
        "targets": [
          {
            "expr": "sum(rate(torq_cognitive_loops_total[1m]))",
            "legendFormat": "Loops/sec"
          },
          {
            "expr": "sum(rate(torq_cognitive_step_total[1m]))",
            "legendFormat": "Steps/sec"
          }
        ],
        "options": {
          "legend": {"displayMode": "table"}
        }
      },
      {
        "id": 3,
        "title": "Reasoning Confidence Trends",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 50, "color": "yellow"},
                {"value": 80, "color": "green"}
              ]
            }
          }
        },
        "targets": [
          {
            "expr": "avg(torq_cognitive_reasoning_confidence) by (session_id)",
            "legendFormat": "{{session_id}}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Tool Success Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "green"}
              ]
            }
          }
        },
        "targets": [
          {
            "expr": "avg(torq_cognitive_act_success_rate)",
            "legendFormat": "Success Rate"
          }
        ]
      },
      {
        "id": 5,
        "title": "Knowledge Retrieval Metrics",
        "type": "stat",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"}
          }
        },
        "targets": [
          {
            "expr": "avg(torq_cognitive_retrieve_count)",
            "legendFormat": "Avg Items Retrieved"
          },
          {
            "expr": "sum(rate(torq_cognitive_retrieve_total[5m]))",
            "legendFormat": "Retrievals/sec"
          }
        ],
        "options": {
          "displayMode": "auto"
        }
      },
      {
        "id": 6,
        "title": "Step-by-Step Timing Breakdown",
        "type": "bargauge",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 16},
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "orientation": "horizontal"
          }
        },
        "targets": [
          {
            "expr": "avg(torq_cognitive_step_duration_ms{step=\"reason\"})",
            "legendFormat": "Reason"
          },
          {
            "expr": "avg(torq_cognitive_step_duration_ms{step=\"retrieve\"})",
            "legendFormat": "Retrieve"
          },
          {
            "expr": "avg(torq_cognitive_step_duration_ms{step=\"plan\"})",
            "legendFormat": "Plan"
          },
          {
            "expr": "avg(torq_cognitive_step_duration_ms{step=\"act\"})",
            "legendFormat": "Act"
          },
          {
            "expr": "avg(torq_cognitive_step_duration_ms{step=\"evaluate\"})",
            "legendFormat": "Evaluate"
          },
          {
            "expr": "avg(torq_cognitive_step_duration_ms{step=\"learn\"})",
            "legendFormat": "Learn"
          }
        ]
      },
      {
        "id": 7,
        "title": "Tools Usage Distribution",
        "type": "piechart",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 16},
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "targets": [
          {
            "expr": "sum by (tool_name) (torq_cognitive_tool_usage_total)",
            "legendFormat": "{{tool_name}}"
          }
        ],
        "options": {
          "legend": {"displayMode": "table"}
        }
      },
      {
        "id": 8,
        "title": "Learning Events Tracking",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": {"mode": "palette-classic"}
          }
        },
        "targets": [
          {
            "expr": "sum by (learning_type) (rate(torq_cognitive_learn_total[5m]))",
            "legendFormat": "{{learning_type}}"
          }
        ]
      },
      {
        "id": 9,
        "title": "Evaluation Outcomes",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"}
          }
        },
        "targets": [
          {
            "expr": "sum(torq_cognitive_evaluate_total{outcome=\"success\"})",
            "legendFormat": "Successful Evaluations"
          },
          {
            "expr": "sum(torq_cognitive_evaluate_total{outcome=\"failure\"})",
            "legendFormat": "Failed Evaluations"
          },
          {
            "expr": "sum(torq_cognitive_evaluate_total{outcome=\"retry\"})",
            "legendFormat": "Retries"
          }
        ],
        "options": {
          "displayMode": "auto",
          "colorMode": "value"
        }
      },
      {
        "id": 10,
        "title": "Active Cognitive Loops by Session",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 34},
        "fieldConfig": {
          "defaults": {
            "custom": {"align": "left"}
          }
        },
        "targets": [
          {
            "expr": "torq_cognitive_loop_active",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"__name__": true, "job": true},
              "indexByName": {},
              "renameByName": {
                "instance": "Instance",
                "loop_id": "Loop ID",
                "session_id": "Session ID",
                "user_query": "User Query"
              }
            }
          }
        ]
      },
      {
        "id": 11,
        "title": "Plan Complexity Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 42},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "spectrum"}
          }
        },
        "targets": [
          {
            "expr": "sum by (complexity) (torq_cognitive_plan_steps_count)",
            "legendFormat": "{{complexity}}"
          }
        ]
      },
      {
        "id": 12,
        "title": "Token Usage Over Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 42},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "targets": [
          {
            "expr": "sum(rate(torq_cognitive_tokens_total[5m]))",
            "legendFormat": "Tokens/sec"
          },
          {
            "expr": "sum(increase(torq_cognitive_tokens_total[1h]))",
            "legendFormat": "Tokens/hour"
          }
        ]
      },
      {
        "id": 13,
        "title": "Error Rate by Step",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 50},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        },
        "targets": [
          {
            "expr": "100 * (sum(rate(torq_cognitive_step_errors_total[5m])) by (step) / sum(rate(torq_cognitive_step_total[5m])) by (step))",
            "legendFormat": "{{step}}"
          }
        ]
      }
    ],
    "variables": {
      "session_id": {
        "name": "session_id",
        "type": "query",
        "query": {
          "query": "label_values(torq_cognitive_loop_active, session_id)",
          "refId": "SessionID"
        }
      },
      "time_range": {
        "name": "time_range",
        "type": "interval",
        "options": ["1m", "5m", "15m", "30m", "1h", "6h", "12h", "24h"],
        "current": {
          "selected": false,
          "text": "5m",
          "value": "5m"
        }
      }
    },
    "annotations": {
      "list": [
        {
          "name": "Cognitive Loop Errors",
          "datasource": "Prometheus",
          "expr": "rate(torq_cognitive_errors_total[1m]) > 0.1",
          "title": "High Error Rate",
          "tags": ["errors", "cognitive"]
        }
      ]
    },
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m"]
    }
  }
}
