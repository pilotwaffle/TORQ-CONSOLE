# TORQ Console — Validation Environment Configuration
#
# This file contains environment variables for Phase 5.1 validation
# against local PostgreSQL. Source this file before running validation.
#
# Usage: load-env .env.validation  (if using load-env utility)
#        or manually export these variables

# ============================================================================
# Database Configuration — Local PostgreSQL
# ============================================================================

# Primary database connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/torq_validation

# Individual database parameters (used by some modules)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=torq_validation
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================================================
# Supabase Configuration (Optional - for vector/embeddings only)
# ============================================================================

# Leave these unset or set to empty to use local DB only
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# ============================================================================
# TORQ Console Settings
# ============================================================================

# Environment
TORQ_ENV=validation

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Mission execution
MAX_CONCURRENT_NODES=5
NODE_TIMEOUT_SECONDS=300
MISSION_TIMEOUT_SECONDS=600

# Handoff settings
HANDOFF_TIMEOUT_SECONDS=60
MAX_HANDOFF_RETRIES=3

# Checkpoint settings
CHECKPOINT_INTERVAL_SECONDS=30
MAX_CHECKPOINTS_PER_MISSION=50

# Validation settings
CAPTURE_TELEMETRY=true
VALIDATION_MODE=true

# ============================================================================
# Optional: External Services (disable for pure local validation)
# ============================================================================

# Anthropic Claude (for agent execution)
# ANTHROPIC_API_KEY=your-key-here

# OpenAI (fallback)
# OPENAI_API_KEY=your-key-here
